# WollyCMS Production Environment
# Copy to .env and fill in values

# REQUIRED: Generate a strong secret (e.g., openssl rand -base64 32)
JWT_SECRET=

# Allowed CORS origins (comma-separated)
CORS_ORIGINS=https://your-site.example.com

# Public site URL (used for webhooks, sitemap links)
SITE_URL=https://your-site.example.com
