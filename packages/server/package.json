{
  "name": "@wollycms/server",
  "version": "0.2.0",
  "type": "module",
  "description": "Self-hosted headless CMS for Astro.js — block-based page building, media management, and content API",
  "author": "Chad Wollenberg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/WollyCMS/wollycms.git",
    "directory": "packages/server"
  },
  "homepage": "https://wollycms.com",
  "bugs": {
    "url": "https://github.com/WollyCMS/wollycms/issues"
  },
  "keywords": [
    "cms",
    "headless-cms",
    "wollycms",
    "astro",
    "hono",
    "block-editor",
    "content-management"
  ],
  "bin": {
    "wolly": "dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./app": "./dist/app.js"
  },
  "files": [
    "dist",
    "drizzle",
    "drizzle-pg"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:generate:pg": "drizzle-kit generate --config drizzle-pg.config.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "build:worker": "node ../../scripts/build-worker.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1017.0",
    "@hono/node-server": "^1.13.0",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "graphql": "^16.13.2",
    "hono": "^4.12.9",
    "pg": "^8.20.0",
    "satori": "^0.26.0",
    "sharp": "^0.34.5",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260317.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.2"
  }
}
